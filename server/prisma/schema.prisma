generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String   @id @default(uuid())
  title        String
  description  String   @db.Text
  technologies String[]
  imageUrl     String[]
  liveUrl      String?
  codeUrl      String?
  featured     Boolean  @default(false)
  projectType  String   @default("personal")  // "personal" or "work"
  vcsType      String   @default("github")    // "github", "gitlab", "bitbucket", "other"
  platformType String   @default("web")       // "web", "mobile", "desktop", "script", "api"
  date         DateTime @default(now())

  // 加速首頁精選、依類型篩選及依日期排序等高頻查詢
  @@index([date])
  @@index([featured])
  @@index([projectType])
}

model Post {
  id         String    @id @default(uuid())
  title      String
  content    String
  excerpt    String
  author     String    @default("Timmy")
  tags       String[]
  coverImage String?
  date       DateTime  @default(now())
  comments   Comment[]

  // 加速分頁排序和最新文章查詢
  @@index([date])
}

model Comment {
  id      String   @id @default(uuid())
  name    String
  email   String
  content String
  date    DateTime @default(now())
  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId  String
}

model User {
  id       String @id @default(uuid())
  name     String @unique @default("Timmy")@map("username")
  email    String @unique
  password String
  role     String @default("USER")
}

model Contact {
  id      String   @id @default(uuid())
  name    String
  email   String
  message String
  date    DateTime @default(now())
  read    Boolean  @default(false)
}

model Activity {
  id          String   @id @default(uuid())
  type        String   
  title       String
  description String?
  userName    String
  targetId    String? 
  targetType  String?  
  date        DateTime @default(now())

  // 加速依時間排序的活動記錄查詢
  @@index([date])
}
